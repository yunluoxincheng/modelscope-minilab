# Copy this file to backend/.env and fill in real secrets. NEVER commit a .env file.

# Application
APP_NAME=ModelScope MiniLab
ENV=dev
DEBUG=true

# Database: use sqlite for dev; switch to mysql+pymysql://user:password@host:3306/minilab?charset=utf8mb4 in prod
DATABASE_URL=sqlite:///./minilab.db

# Redis: redis://host:6379/0
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# WeChat login
# Set WECHAT_AUTH_MOCK=true ONLY in local dev. NEVER in production.
WECHAT_AUTH_MOCK=true
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Rate limits
PREDICT_RATE_PER_USER_PER_MINUTE=20
PREDICT_RATE_PER_IP_PER_MINUTE=60
PUBLIC_RATE_PER_IP_PER_MINUTE=120

# Upload limits
MAX_UPLOAD_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp

# Cat-Dog ensemble
CAT_DOG_ENSEMBLE_WEIGHTS=5:1:3
CAT_DOG_V2_PATH=ml_assets/cat_dog/checkpoints/efficientnet_b0_v2.pth
CAT_DOG_V3_PATH=ml_assets/cat_dog/checkpoints/efficientnet_b0_v3.pth
CAT_DOG_V4_PATH=ml_assets/cat_dog/checkpoints/efficientnet_b0_v4.pth
CAT_DOG_IMG_SIZE=256
CAT_DOG_THRESHOLD=0.5
CAT_DOG_FAST_MODE=false

# Service window (set SERVICE_WINDOW_ENFORCE=true to enforce 10:00-18:00)
SERVICE_WINDOW_START=10:00
SERVICE_WINDOW_END=18:00
SERVICE_WINDOW_ENFORCE=false

# CORS (comma separated origins)
CORS_ALLOW_ORIGINS=
