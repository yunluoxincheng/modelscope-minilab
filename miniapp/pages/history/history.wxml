<!--pages/history/history.wxml-->
<view class="container">
  <view class="title">识别历史</view>
  <view class="subtitle">仅展示当前账号下的最近识别记录</view>

  <block wx:if="{{!loggedIn}}">
    <view class="card">
      <view class="muted">登录后可查看历史记录</view>
      <view class="primary-btn" style="margin-top: 16rpx;" bindtap="goLogin">去登录</view>
    </view>
  </block>

  <block wx:elif="{{loading && items.length === 0}}">
    <view class="card muted">加载中…</view>
  </block>

  <block wx:elif="{{items.length === 0}}">
    <view class="empty">暂无识别记录</view>
  </block>

  <block wx:else>
    <view class="card" wx:for="{{items}}" wx:key="id">
      <view class="row">
        <text class="row__label">{{item.result_label_cn}}</text>
        <text class="muted">{{item.model_id}}</text>
      </view>
      <view class="row muted">
        <text>置信度 {{item.confidence}}</text>
        <text>{{item.created_at}}</text>
      </view>
      <view class="row muted" wx:if="{{item.latency_ms}}">
        <text>耗时 {{item.latency_ms}} ms</text>
        <text>{{item.status}}</text>
      </view>
    </view>
    <view class="muted center" wx:if="{{items.length >= total}}">没有更多了</view>
  </block>
</view>
