.desc {
  margin: 16rpx 0;
  color: #334155;
}

.meta {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.preview {
  margin: 16rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F1F5F9;
}

.preview image {
  width: 100%;
  height: 420rpx;
  display: block;
}

.result {
  margin: 24rpx 0;
  text-align: center;
}

.result__label {
  font-size: 96rpx;
  font-weight: 800;
  color: #2563EB;
  letter-spacing: 8rpx;
}

.center {
  text-align: center;
}
