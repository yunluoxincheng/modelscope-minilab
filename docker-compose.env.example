# ====================================================================
# ModelScope MiniLab / 智模工坊 —— docker-compose 部署环境变量模板
#
# 用法：复制为 .env 后按需修改。此文件不要提交到仓库。
#   cp docker-compose.env.example .env
# ====================================================================

# ---- 应用 ----
APP_NAME=ModelScope MiniLab
ENV=prod
DEBUG=false

# ---- 数据库 ----
# 默认用 SQLite（数据落在 docker-compose.yml 里的 minilab-data 卷，重启不丢）。
DATABASE_URL=sqlite:///./data/minilab.db
#
# 如果启用了 mysql（docker compose --profile mysql up -d），改用下面这行：
# DATABASE_URL=mysql+pymysql://minilab:你的MYSQL_PASSWORD@mysql:3306/minilab?charset=utf8mb4
#
# MySQL 容器自身的初始化参数（仅 --profile mysql 时生效）：
MYSQL_ROOT_PASSWORD=please-change-root-password
MYSQL_DATABASE=minilab
MYSQL_USER=minilab
MYSQL_PASSWORD=please-change-minilab-password

# ---- Redis（compose 里已强制为 redis://redis:6379/0，这里仅占位）----
REDIS_URL=redis://redis:6379/0

# ---- JWT（生产必须改成 32 字节以上的随机串，可用 openssl rand -hex 32 生成）----
JWT_SECRET=please-replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ---- 微信登录（生产必须关闭 mock，并填真实 AppID / AppSecret）----
WECHAT_AUTH_MOCK=false
WECHAT_APP_ID=wx75fdf5fd30a795d3
WECHAT_APP_SECRET=

# ---- 限流 ----
PREDICT_RATE_PER_USER_PER_MINUTE=20
PREDICT_RATE_PER_IP_PER_MINUTE=60
PUBLIC_RATE_PER_IP_PER_MINUTE=120

# ---- 上传限制 ----
MAX_UPLOAD_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp

# ---- 猫狗集成模型（EfficientNet-B0 v2/v3/v4，权重 5:1:3）----
CAT_DOG_ENSEMBLE_WEIGHTS=5:1:3
CAT_DOG_IMG_SIZE=256
CAT_DOG_THRESHOLD=0.5
CAT_DOG_FAST_MODE=false

# ---- 服务时间窗口（10:00-18:00；想 7×24 就设 false）----
SERVICE_WINDOW_START=10:00
SERVICE_WINDOW_END=18:00
SERVICE_WINDOW_ENFORCE=true

# ---- CORS（小程序不需要，留空）----
CORS_ALLOW_ORIGINS=
